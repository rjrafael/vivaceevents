rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile photos — owner writes, authenticated users read
    match /profiles/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Contracts - only accessible by named parties
    match /contracts/{contractId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.metadata.managerEmail ||
        request.auth.token.email == resource.metadata.musicianEmail
      );
      allow write: if request.auth != null;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
