rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function isOwnerEmail(email) {
      return signedIn() && request.auth.token.email == email;
    }

    // ─── Users (public profile data) ───────────────────────────
    // Public profile fields only. Email/phone/tokens live in users_private below.
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── Users PRIVATE (sensitive contact info — locked) ───────
    // ONLY the owner can read. This stops bulk harvesting of emails/phones.
    match /users_private/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ─── Gigs ──────────────────────────────────────────────────
    match /gigs/{gigId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Applications ──────────────────────────────────────────
    match /applications/{appId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.managerId == request.auth.uid
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Groups (legacy) ───────────────────────────────────────
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── Venues ────────────────────────────────────────────────
    match /venues/{venueId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── Broadcasts ────────────────────────────────────────────
    match /broadcasts/{bid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.fromId == request.auth.uid;
    }

    // ─── Responses ─────────────────────────────────────────────
    match /responses/{rid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Contracts ─────────────────────────────────────────────
    match /contracts/{cid} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // ─── Messages ──────────────────────────────────────────────
    match /messages/{mid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.fromId == request.auth.uid;
    }

    // ─── Notifications ─────────────────────────────────────────
    match /notifications/{nid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    // ─── Connections ───────────────────────────────────────────
    match /connections/{cid} {
      allow read, write: if signedIn();
    }

    // ─── Ratings ───────────────────────────────────────────────
    match /ratings/{rid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.raterId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.raterId == request.auth.uid;
    }

    // ─── Gift Codes ────────────────────────────────────────────
    match /giftCodes/{gid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    // ─── Radio Tracks ──────────────────────────────────────────
    match /radioTracks/{tid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }

    // ─── Lessons ───────────────────────────────────────────────
    match /lessons/{lid} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if signedIn();
    }

    // ─── Invites ───────────────────────────────────────────────
    match /invites/{iid} {
      allow read, write: if signedIn();
    }

    // ─── Mail (outbound emails) ────────────────────────────────
    match /mail/{mid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // ─── Stripe Waitlist ───────────────────────────────────────
    match /stripeWaitlist/{wid} {
      allow read, write: if signedIn();
    }

    // ─── Cancellations ─────────────────────────────────────────
    match /cancellations/{cid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // ─── ROSTER FOLDERS (NEW — Phase 1) ────────────────────────
    match /rosterFolders/{folderId} {
      allow read: if signedIn() && resource.data.managerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── ROSTER MEMBERS (locked — only the manager who owns reads) ────
    match /rosterMembers/{memberId} {
      allow read: if signedIn() && resource.data.managerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── USERNAMES (unique handle reservations) ────────────────
    match /usernames/{username} {
      allow read: if true;  // anyone can check if a username is taken
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── PUSH QUEUE (Cloud Function reads & deletes) ───────────
    match /pushQueue/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    // ─── Fallback — deny unknown collections ───────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
