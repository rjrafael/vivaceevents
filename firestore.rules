rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function isOwnerEmail(email) {
      return signedIn() && request.auth.token.email == email;
    }

    // ─── Users (public profile data) ───────────────────────────
    // Public profile fields only. Email/phone/tokens live in users_private below.
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── Users PRIVATE (sensitive contact info — locked) ───────
    // ONLY the owner can read. This stops bulk harvesting of emails/phones.
    match /users_private/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ─── Gigs ──────────────────────────────────────────────────
    match /gigs/{gigId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Applications ──────────────────────────────────────────
    match /applications/{appId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.managerId == request.auth.uid
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Groups (legacy) ───────────────────────────────────────
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── Venues ────────────────────────────────────────────────
    match /venues/{venueId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── Broadcasts ────────────────────────────────────────────
    match /broadcasts/{bid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.fromId == request.auth.uid;
    }

    // ─── Responses ─────────────────────────────────────────────
    match /responses/{rid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Contracts ─────────────────────────────────────────────
    match /contracts/{cid} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    // ─── Messages ──────────────────────────────────────────────
    match /messages/{mid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.senderId == request.auth.uid;
    }

    // ─── Conversations (DM threads between two users) ──────────
    match /conversations/{cid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;
    }

    // ─── Notifications ─────────────────────────────────────────
    match /notifications/{nid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    // ─── Connections ───────────────────────────────────────────
    match /connections/{cid} {
      allow read, write: if signedIn();
    }

    // ─── Ratings ───────────────────────────────────────────────
    match /ratings/{rid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.raterId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.raterId == request.auth.uid;
    }

    // ─── Gift Codes ────────────────────────────────────────────
    match /giftCodes/{gid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    // ─── Radio Tracks ──────────────────────────────────────────
    match /radioTracks/{tid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uploaderId == request.auth.uid;
    }

    // ─── Lessons ───────────────────────────────────────────────
    match /lessons/{lid} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if signedIn();
    }

    // ─── Invites ───────────────────────────────────────────────
    match /invites/{iid} {
      allow read, write: if signedIn();
    }

    // ─── Mail (outbound emails) ────────────────────────────────
    match /mail/{mid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // ─── Stripe Waitlist ───────────────────────────────────────
    match /stripeWaitlist/{wid} {
      allow read, write: if signedIn();
    }

    // ─── Cancellations ─────────────────────────────────────────
    match /cancellations/{cid} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // ─── ROSTER FOLDERS (NEW — Phase 1) ────────────────────────
    match /rosterFolders/{folderId} {
      allow read: if signedIn() && resource.data.managerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.managerId == request.auth.uid;
    }

    // ─── ROSTER MEMBERS (locked — only the manager who owns reads) ────
    match /rosterMembers/{memberId} {
      // Manager (owner) has full access to their roster
      allow read: if signedIn() && resource.data.managerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.managerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.managerId == request.auth.uid;
      // Manager updates freely. An invited user may claim an unlinked placeholder
      // ONLY if it matches their own email AND they set musicianId to their own uid.
      allow update: if signedIn() && (
        resource.data.managerId == request.auth.uid
        || (
          resource.data.musicianId == ''
          && resource.data.musicianEmail == request.auth.token.email
          && request.resource.data.musicianId == request.auth.uid
        )
      );
      // An invited user may read a placeholder ONLY if it's addressed to their own email.
      allow read: if signedIn()
        && resource.data.musicianId == ''
        && resource.data.musicianEmail == request.auth.token.email;
    }

    // ─── USERNAMES (unique handle reservations) ────────────────
    match /usernames/{username} {
      allow read: if true;  // anyone can check if a username is taken
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── PUSH QUEUE (Cloud Function reads & deletes) ───────────
    match /pushQueue/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    // ─── META (signup counter for Founding Member badge) ───────
    // Any signed-in user can read + increment the counter at signup.
    match /meta/{docId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ─── AVAILABILITY (each user's calendar) ───────────────────
    // Owner reads/writes their own. Others can READ (managers check availability before booking).
    match /availability/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && userId == request.auth.uid;
    }

    // ─── ORGANIZER EVENTS (owner-only) ─────────────────────────
    match /organizer_events/{eventId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── EVENT GUESTS (sealed private groups) ──────────────────
    // Organizer owns the list. An invited guest may claim their own slot
    // ONLY if it matches their verified email (same pattern as rosterMembers).
    match /event_guests/{guestId} {
      allow read: if signedIn() && resource.data.organizerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.organizerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.organizerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.organizerId == request.auth.uid
        || (
          resource.data.guestId == ''
          && resource.data.guestEmail == request.auth.token.email
          && request.resource.data.guestId == request.auth.uid
        )
      );
      allow read: if signedIn()
        && resource.data.guestId == ''
        && resource.data.guestEmail == request.auth.token.email;
    }

    // ─── EVENT SEATING (floor plans — organizer owns) ──────────
    match /event_seating/{seatingId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.organizerId == request.auth.uid;
    }

    // ─── Fallback — deny unknown collections ───────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
